rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // 1. Global Safety Net (Default-Deny Catch-All)
    match /{document=**} {
      allow read, write: if false;
    }

    // --- REUSABLE SECURITY HELPERS (Zero-Trust/ABAC) ---
    
    function isSignedIn() {
      return request.auth != null;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    // Checks if the authenticated user has an ADMIN role in the 'users' collection
    function isAdmin() {
      return isSignedIn() && 
        exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'ADMIN';
    }

    // Verify user is reading their own document or is an administrator
    function isOwner(userId) {
      return isSignedIn() && (request.auth.uid == userId || isAdmin());
    }

    // --- COLLECTION RULES ---

    // 1. Users collection
    match /users/{userId} {
      allow get: if isOwner(userId);
      allow list: if isAdmin(); // Strictly prevent bulk directory scraping
      allow create, update, delete: if false; // All writes must be proxied by backend
    }

    // 2. Elections collection
    match /elections/{electionId} {
      allow get: if isSignedIn() && isValidId(electionId) && (
        resource.data.status != 'DRAFT' || 
        resource.data.createdBy == request.auth.uid || 
        isAdmin()
      );
      
      // Query Enforcer pattern: prevent blanket lists, verify query filters non-draft unless admin/creator
      allow list: if isSignedIn() && (
        resource.data.status != 'DRAFT' || 
        resource.data.createdBy == request.auth.uid || 
        isAdmin()
      );
      
      allow create, update, delete: if false; // Block client-side writes
    }

    // 3. Voter Eligibilities collection
    match /voterEligibilities/{eligibilityId} {
      allow get: if isSignedIn() && isValidId(eligibilityId) && (
        resource.data.userId == request.auth.uid || 
        isAdmin()
      );
      
      // Query Enforcer pattern for list queries
      allow list: if isSignedIn() && (
        resource.data.userId == request.auth.uid || 
        isAdmin()
      );
      
      allow create, update, delete: if false; // Block client-side writes
    }

    // 4. Encrypted Ballots collection
    match /encryptedBallots/{ballotId} {
      // Allow authenticated users to view the public immutable ledger entries
      allow get: if isSignedIn() && isValidId(ballotId);
      allow list: if isSignedIn() && resource.data.electionId != null;
      
      allow create, update, delete: if false; // Block client-side writes
    }

    // 5. Audit Logs collection
    match /auditLogs/{logId} {
      // Allow authenticated users to view the public blockchain ledger entries
      allow get: if isSignedIn() && isValidId(logId);
      allow list: if isSignedIn() && resource.data.electionId != null;
      
      allow create, update, delete: if false; // Block client-side writes
    }

    // 6. Tallies collection
    match /tallies/{tallyId} {
      allow get: if isSignedIn() && isValidId(tallyId);
      allow list: if isSignedIn() && resource.data.electionId != null;
      
      allow create, update, delete: if false; // Block client-side writes
    }

    // 7. Private Keys Store (Confidential Secret, STRICT Isolation)
    match /privateKeysStore/{keyId} {
      allow read, write: if false; // Zero-trust isolation: even logged-in admins cannot access from client
    }
  }
}
