# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# Database Configuration (Docker Compose & Next.js/FastAPI)
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres_secure_password
POSTGRES_DB=cryptolab_elections
DATABASE_URL="postgresql://postgres:postgres_secure_password@db:5432/cryptolab_elections?schema=public"

# Authentication Config
JWT_SECRET=super_secret_jwt_key_for_cryptolab_elections

# Crypto Engine Options
RSA_KEY_SIZE_DEFAULT=2048
PAILLIER_KEY_SIZE_DEFAULT=2048

